        "image_HNdcFx": {
          "type": "image",
          "settings": {
            "image_pc": "shopify://shop_images/360_F_1437099879_BNeF4E3Inr28ozf0rykpk13LR4Y8UJh6.jpg",
            "image_sp": "shopify://shop_images/360_F_1437099879_BNeF4E3Inr28ozf0rykpk13LR4Y8UJh6.jpg",
            "textarea": "“I’ve been taking AG1 for about four years now. It’s the first thing I do after I start my day. The ingredients are clean, they’re healthy, and it sort of has everything that you need to start the day. I just feel like my health is a lot better, and more consistent with my energy level as well.”"
          }
        },
        "image_GRGzia": {
          "type": "image",
          "settings": {
            "image_pc": "shopify://shop_images/33921501_m.jpg",
            "image_sp": "shopify://shop_images/33921501_m.jpg",
            "textarea": "AG1を飲み始めてもう4年になります。一日が始まって最初にやることなんです。成分はクリーンでヘルシーで、一日のスタートに必要なものがすべて揃っています。おかげで健康状態がずっと良くなった気がしますし、エネルギーレベルも安定してきました。"
          }
        },
        "image_FftiPW": {
          "type": "image",
          "settings": {
