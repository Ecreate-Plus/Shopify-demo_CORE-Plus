<div class="card__information c-card__information">
  {% comment %} 商品名・補足・サブキャッチ {% endcomment %}
  {% if card_product.title != blank %}
    <div class="c-custom-card__title-area">
      <h3
        class="card__heading h5 c-card__heading"
        id="title-{{ section_id }}-{{ card_product.id }}"
      >
        <a
          href="{{ card_product.url }}"
          id="CardLink-{{ section_id }}-{{ card_product.id }}"
          class="full-unstyled-link"
          aria-labelledby="CardLink-{{ section_id }}-{{ card_product.id }} Badge-{{ section_id }}-{{ card_product.id }}"
        >
          {{ card_product.title | escape }}
        </a>
      </h3>
    </div>
  {% endif %}

  {% if card_product.metafields.custom.flavor != blank %}
    {% if card_product.metafields.custom.flavor != blank %}
      <div>
        <span class="c-card-info__additional-title">{{ card_product.metafields.custom.flavor }}</span>
      </div>
    {% endif %}

    <hr class="c-custom-card__divider">
  {% endif %}

  {% comment %} 商品説明 {% endcomment %}
  {% if card_product.metafields.custom.description != blank %}
    <div class="c-custom-card__desc-area">
      <p class="c-custom-card__desc">
        {{ card_product.metafields.custom.description }}
      </p>
    </div>
    <hr class="c-custom-card__divider">
  {% endif %}

  {% comment %} カロリーなどの補足情報 {% endcomment %}
  {% if card_product.metafields.custom.protein_label != blank or card_product.metafields.custom.protein != blank %}
    <div class="c-nutrition-item">
      <svg width="30" height="20" viewBox="0 0 30 20" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M26.5127 0.5C27.2831 0.5 28.0192 0.915534 28.5791 1.66211C29.139 2.40883 29.5 3.46329 29.5 4.64941V5.12695C29.5 6.76603 28.8029 8.19713 27.7949 8.86914C27.3911 9.13831 27.2413 9.60971 27.2412 10C27.2412 10.3904 27.3911 10.8617 27.7949 11.1309C28.8029 11.8029 29.5 13.2334 29.5 14.873V15.3506C29.5 16.5368 29.1381 17.5911 28.5781 18.3379C28.0182 19.0845 27.2828 19.5 26.5127 19.5C25.3228 19.4998 24.1321 18.465 23.6904 16.7002C23.5507 16.1409 23.4069 15.3522 23.1348 14.7461C22.9934 14.4314 22.7988 14.1192 22.5146 13.8838C22.2199 13.6396 21.8542 13.5001 21.4189 13.5H8.58105C8.1696 13.5 7.81555 13.6171 7.52344 13.8418C7.24058 14.0594 7.04702 14.3539 6.9043 14.6582C6.63081 15.2416 6.47765 16.0282 6.30957 16.7002C5.86792 18.4653 4.67681 19.5 3.48633 19.5C2.71626 19.4999 1.98074 19.0844 1.4209 18.3379C0.861076 17.5912 0.5 16.5367 0.5 15.3506V14.873C0.500022 13.234 1.19707 11.8029 2.20508 11.1309C2.60886 10.8617 2.75879 10.3904 2.75879 10C2.75879 9.60963 2.60886 9.13831 2.20508 8.86914C1.19707 8.19713 0.500022 6.76603 0.5 5.12695V4.64941L0.503906 4.42871C0.545592 3.33273 0.896001 2.36219 1.4209 1.66211C1.98083 0.915534 2.71688 0.5 3.4873 0.5C4.67728 0.500159 5.86845 1.53494 6.30957 3.2998C6.44931 3.85906 6.59309 4.64775 6.86523 5.25391C7.00653 5.56854 7.20038 5.88086 7.48438 6.11621C7.77924 6.36052 8.14562 6.5 8.58105 6.5H21.4189C21.8304 6.49993 22.1845 6.38294 22.4766 6.1582C22.7595 5.94052 22.953 5.6462 23.0957 5.3418C23.3692 4.75835 23.5223 3.97184 23.6904 3.2998C24.1321 1.53493 25.3223 0.500158 26.5127 0.5Z" fill="white" stroke="black"/>
      </svg>

      <div class="c-nutrition-text">
        <span>{{- card_product.metafields.custom.protein_label | append: '：' -}}</span>
        <span>{{- card_product.metafields.custom.protein | append: 'g' -}}</span>
      </div>
    </div>
  {% endif %}
  {% if card_product.metafields.custom.calorie_label != blank or card_product.metafields.custom.calories != blank %}
    <div class="c-nutrition-item">
      <svg
        width="25"
        height="25"
        viewBox="0 0 25 25"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        xmlns:xlink="http://www.w3.org/1999/xlink"
      >
        <rect width="25" height="25" fill="url(#pattern0_343_271)"/>
        <defs>
        <pattern id="pattern0_343_271" patternContentUnits="objectBoundingBox" width="1" height="1">
        <use xlink:href="#image0_343_271" transform="translate(-0.0434783 -0.0434783) scale(0.00271739)"/>
        </pattern>
        <image id="image0_343_271" width="400" height="400" preserveAspectRatio="none" xlink:href="data:image/png;base64,"/>
        </defs>
      </svg>

      <div class="c-nutrition-text">
        <span>{{- card_product.metafields.custom.calorie_label | append: '：' }}</span>
        <span> {{ card_product.metafields.custom.calories | append: 'kcal' -}}</span>
      </div>
    </div>
    <hr class="c-custom-card__divider">
  {% endif %}
  {% comment %} 価格など {% endcomment %}
  {% if card_product.price != blank or card_product.metafields.custom.unit_count.value != blank %}
    <div class="c-custom-card__price-area">
      {%- liquid
        assign unit_count = card_product.metafields.custom.unit_count.value
        assign unit_name = card_product.metafields.custom.count_name.value | default: '本'
        assign per_unit = card_product.price | divided_by: unit_count
      -%}

      <p class="price-text c-price_text">
        <span class="price-per-unit"
          >1{{ unit_name }}
          {{ per_unit | money | append: ' / ' -}}
        </span>
        <span class="price-total">{{ card_product.price | money | append: 'から' }}</span>
      </p>
      {% if card_product.metafields.custom.subscription_notice != blank %}
        <p class="c-subscription-notice">{{ card_product.metafields.custom.subscription_notice }}</p>
      {% endif %}
    </div>
  {% endif %}
</div>
